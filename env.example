# Paytm TrustScore — Environment Variables
# Copy this file to .env and fill in your Supabase project credentials.
# DO NOT commit your actual .env file to version control.

# Found in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → anon (public) key
# This is a PUBLIC key — safe to use in frontend code.
# NEVER use your service_role key here.
SUPABASE_ANON_KEY=your-anon-public-key-here
